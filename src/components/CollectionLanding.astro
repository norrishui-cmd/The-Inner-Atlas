---
import Base from '../layouts/Base.astro';
import Newsletter from './Newsletter.astro';
const { title, description, eyebrow, h1, lede, image, intention, meaning, materials, ritual, questions, source } = Astro.props;
const siteOrigin=Astro.site ?? new URL('https://dunhuangwithin.com/');
const schema={
  '@context':'https://schema.org','@graph':[
    {'@type':'CollectionPage',name:title,description,url:new URL(Astro.url.pathname,siteOrigin).href,isPartOf:{'@type':'WebSite',name:'Dunhuang Within',url:'https://dunhuangwithin.com/'}},
    {'@type':'FAQPage',mainEntity:questions.map((q:any)=>({'@type':'Question',name:q.q,acceptedAnswer:{'@type':'Answer',text:q.a}}))}
  ]
};
---
<Base title={title} description={description} schema={schema}>
  <section class="collection-hero" style={`--collection-image:url('${image}')`}><div class="wrap"><p class="eyebrow">{eyebrow}</p><h1>{h1}</h1><p class="lede">{lede}</p><div class="actions"><a class="button" href="#waitlist" data-seo-event="waitlist_click">Join the First Release</a><a class="button secondary" href="/find-your-path/" data-seo-event="find_path_click">Find Your Path</a></div></div></section>
  <article class="article collection-copy"><p class="eyebrow">The intention</p><h2>{intention.title}</h2><p>{intention.copy}</p><h2>Cultural meaning before material</h2><p>{meaning}</p><h2>Materials under consideration</h2><p>{materials}</p><p>Final product pages will identify every material, treatment, maker and source. No stone or object will be presented as medical treatment or guaranteed supernatural protection.</p><h2>A practice for wearing it</h2><p>{ritual}</p><h2>Questions people ask</h2>{questions.map((item:any)=><section class="faq"><h3>{item.q}</h3><p>{item.a}</p></section>)}<div class="related-commerce"><a href="/objects/" data-seo-event="category_click">Explore all future collections</a><a href="/symbols/">Understand Dunhuang symbols</a><a href="/places/dunhuang/spiritual-jewelry/">Read the spiritual jewelry guide</a></div></article>
  <section class="section tint" id="waitlist"><div class="wrap"><Newsletter heading="Be first to enter the collection" copy="Join the private release list for design notes, cultural sources and first access when this collection becomes available." buttonLabel="Join the First Release" source={source} /></div></section>
</Base>
<style>.collection-hero{min-height:78vh;display:flex;align-items:end;padding:10rem 0 6rem;color:var(--moonlight);background:linear-gradient(90deg,rgba(15,16,12,.96),rgba(15,16,12,.42)),var(--collection-image) center/cover}.collection-hero h1{max-width:900px}.collection-copy{padding-top:6rem}.faq{padding:1.5rem 0;border-bottom:1px solid var(--line)}.faq h3{margin-bottom:.6rem}.related-commerce{display:grid;grid-template-columns:repeat(3,1fr);margin-top:4rem;border-block:1px solid var(--line)}.related-commerce a{padding:1.5rem;border-right:1px solid var(--line);text-decoration:none}@media(max-width:700px){.collection-hero{min-height:68vh;padding:8rem 0 4rem}.related-commerce{grid-template-columns:1fr}.related-commerce a{border-right:0;border-bottom:1px solid var(--line)}}</style>
