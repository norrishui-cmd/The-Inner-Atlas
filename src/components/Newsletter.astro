---
const { compact = false, heading, copy, buttonLabel, source = 'weekly-journey' } = Astro.props;
---
<aside class="newsletter">
  <h2>{heading ?? (compact ? 'Continue the path' : 'One path from Dunhuang each week')}</h2>
  <p>{copy ?? 'A Dunhuang story, a question, and a small practice for the space between chapters.'}</p>
  <form data-newsletter data-source={source}>
    <label class="sr-only" for="newsletter-email">Email address</label>
    <input id="newsletter-email" required type="email" name="email" placeholder="you@example.com" autocomplete="email" />
    <button class="button" type="submit">{buttonLabel ?? 'Send Me the Next Path'}</button>
  </form>
  <p class="status" role="status"></p>
</aside>
<script>
  import { subscribe } from '../lib/newsletter';
  import { track } from '../lib/analytics';
  document.querySelectorAll<HTMLFormElement>('[data-newsletter]').forEach(form => form.addEventListener('submit', async e => {
    e.preventDefault(); const status=form.parentElement?.querySelector<HTMLElement>('.status'); const email=new FormData(form).get('email')?.toString() || '';
    const source=form.dataset.source || 'weekly-journey'; if(status) status.textContent='Sending…'; const result=await subscribe(email,source); if(status) status.textContent=result.message; if(result.ok){track('email_submit',{source});form.reset();}
  }));
</script>
