---
import '../styles/global.css';
import '../styles/mobile.css';
const { title, description, image='/og.png', type='website', noindex=false, schema, transparentHeader=false } = Astro.props;
const canonical=new URL(Astro.url.pathname,Astro.site); const fullTitle=title.includes('Dunhuang Within')?title:`${title} | Dunhuang Within`;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><title>{fullTitle}</title><meta name="description" content={description}><link rel="canonical" href={canonical}><link rel="sitemap" href="/sitemap-index.xml" />{googleSiteVerification&&<meta name="google-site-verification" content={googleSiteVerification} />}<meta property="og:title" content={fullTitle}><meta property="og:description" content={description}><meta property="og:type" content={type}><meta property="og:url" content={canonical}><meta property="og:image" content={new URL(image,Astro.site)}><meta name="twitter:card" content="summary_large_image">{noindex&&<meta name="robots" content="noindex,nofollow">}<link rel="icon" href="/favicon.svg">{schema&&<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}</head><body>
<header class:list={["site-header",{"on-light":!transparentHeader}]}><div class="wrap nav"><a class="brand" href="/">DUNHUANG WITHIN</a><nav aria-label="Primary"><a href="/places/dunhuang/">Enter Dunhuang</a><a href="/dunhuang-map/">Trail Map</a><a href="/paths/">Paths</a><a href="/practices/">Practices</a><a href="/symbols/">Symbols</a><a href="/objects/">Objects</a><a href="/journal/">Journal</a></nav><a class="button" href="/find-your-path/">Find Your Path</a><details class="mobile-menu"><summary>Menu</summary><nav class="mobile-panel" aria-label="Mobile"><a href="/places/dunhuang/">Enter Dunhuang</a><a href="/dunhuang-map/">Trail Map</a><a href="/paths/">Paths</a><a href="/practices/">Practices</a><a href="/symbols/">Symbols</a><a href="/objects/">Objects</a><a href="/journal/">Journal</a><a href="/find-your-path/">Find Your Path</a></nav></details></div></header><main><slot /></main>
<footer class="footer"><div class="wrap footer-grid"><div><a class="brand" href="/">DUNHUANG WITHIN</a><p>Quiet journeys for the space between chapters. Enter Dunhuang. Listen inward.</p></div><div><strong>Enter</strong><a href="/places/dunhuang/">Dunhuang</a><a href="/brand-story/">Brand Story</a><a href="/paths/">Paths</a><a href="/practices/">Practices</a><a href="/symbols/">Symbols</a><a href="/objects/">Objects</a></div><div><strong>Journal & Trust</strong><a href="/journal/">Journal</a><a href="/about/">About</a><a href="/editorial-principles/">Editorial Principles</a><a href="/sources-and-methodology/">Sources</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a></div></div></footer>
</body></html>
