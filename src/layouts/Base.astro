---
import '../styles/global.css';
import '../styles/mobile.css';
const { title, description, image='/og.png', type='website', noindex=false, schema, transparentHeader=false } = Astro.props;
const siteOrigin=Astro.site ?? new URL('https://dunhuangwithin.com/');
const canonical=new URL(Astro.url.pathname,siteOrigin); const fullTitle=title.includes('Dunhuang Within')?title:`${title} | Dunhuang Within`;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const entitySchema={'@context':'https://schema.org','@graph':[{'@type':'Organization','@id':'https://dunhuangwithin.com/#organization',name:'Dunhuang Within',url:'https://dunhuangwithin.com/',logo:{'@type':'ImageObject',url:'https://dunhuangwithin.com/og.png'},description:'A cultural brand translating documented Dunhuang art, symbols and landscapes into contemporary paths, practices and objects of intention for wearing, carrying, placing and reflecting.'},{'@type':'WebSite','@id':'https://dunhuangwithin.com/#website',url:'https://dunhuangwithin.com/',name:'Dunhuang Within',publisher:{'@id':'https://dunhuangwithin.com/#organization'},inLanguage:'en'}]};
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><title>{fullTitle}</title><meta name="description" content={description}><meta name="robots" content={noindex?'noindex,nofollow':'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'}><link rel="canonical" href={canonical}><link rel="sitemap" href="/sitemap-index.xml" /><link rel="alternate" type="application/atom+xml" title="Dunhuang Within" href="/feed.xml" />{googleSiteVerification&&<meta name="google-site-verification" content={googleSiteVerification} />}<meta property="og:title" content={fullTitle}><meta property="og:description" content={description}><meta property="og:type" content={type}><meta property="og:url" content={canonical}><meta property="og:site_name" content="Dunhuang Within"><meta property="og:image" content={new URL(image,siteOrigin)}><meta property="og:image:alt" content={title}><meta name="twitter:card" content="summary_large_image"><meta name="twitter:title" content={fullTitle}><meta name="twitter:description" content={description}><meta name="twitter:image" content={new URL(image,siteOrigin)}><link rel="icon" href="/favicon.svg"><script is:inline type="application/ld+json" set:html={JSON.stringify(entitySchema)} />{schema&&<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}</head><body>
<header class:list={["site-header",{"on-light":!transparentHeader}]}><div class="wrap nav"><a class="brand" href="/">DUNHUANG WITHIN</a><nav aria-label="Primary"><a href="/places/dunhuang/">Enter Dunhuang</a><a href="/dunhuang-map/">Trail Map</a><a href="/paths/">Paths</a><a href="/practices/">Practices</a><a href="/symbols/">Symbols</a><a class="nav-shop" href="/objects/">Shop</a><a href="/journal/">Journal</a><a href="/about/">About Us</a></nav><a class="button" href="/find-your-path/" data-seo-event="find_path_click">Find Your Path</a><details class="mobile-menu"><summary>Menu</summary><nav class="mobile-panel" aria-label="Mobile"><a href="/places/dunhuang/">Enter Dunhuang</a><a href="/dunhuang-map/">Trail Map</a><a href="/paths/">Paths</a><a href="/practices/">Practices</a><a href="/symbols/">Symbols</a><a href="/objects/">Shop</a><a href="/journal/">Journal</a><a href="/about/">About Us</a><a href="/find-your-path/" data-seo-event="find_path_click">Find Your Path</a></nav></details></div></header><main><slot /></main>
<footer class="footer"><div class="wrap footer-grid"><div><a class="brand" href="/">DUNHUANG WITHIN</a><p>Quiet journeys for the space between chapters. Enter Dunhuang. Listen inward.</p></div><div><strong>Enter</strong><a href="/places/dunhuang/">Dunhuang</a><a href="/brand-story/">Brand Story</a><a href="/paths/">Paths</a><a href="/practices/">Practices</a><a href="/symbols/">Symbols</a><a href="/objects/">Shop</a><a href="/spiritual-jewelry/">Jewelry Guides</a></div><div><strong>Journal & Trust</strong><a href="/journal/">Journal</a><a href="/about/">About</a><a href="/authors/dunhuang-within-editorial-team/">Editorial Team</a><a href="/editorial-principles/">Editorial Principles</a><a href="/sources-and-methodology/">Sources</a><a href="/site-map/">Site Map</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a></div></div></footer>
<style is:global>.nav>nav .nav-shop{padding:.48rem .75rem;border:1px solid currentColor}.nav>nav .nav-shop:after{display:none}.nav>nav .nav-shop:hover{background:var(--faded-clay);border-color:var(--faded-clay);color:#fff}</style>
<script>
  import { track } from '../lib/analytics';
  document.addEventListener('click',(event)=>{const target=(event.target as HTMLElement).closest<HTMLElement>('[data-seo-event]');if(!target)return;const name=target.dataset.seoEvent as Parameters<typeof track>[0];track(name,{destination:target.getAttribute('href')||'',label:target.textContent?.trim().slice(0,80)||''});});
</script>
</body></html>
