---
import '../styles/global.css';
const { title, description, image='/og.png', type='website', noindex=false, schema } = Astro.props;
const canonical=new URL(Astro.url.pathname,Astro.site); const fullTitle=title.includes('The Inner Atlas')?title:`${title} | The Inner Atlas`;
---
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width"><title>{fullTitle}</title><meta name="description" content={description}><link rel="canonical" href={canonical}><meta property="og:title" content={fullTitle}><meta property="og:description" content={description}><meta property="og:type" content={type}><meta property="og:url" content={canonical}><meta property="og:image" content={new URL(image,Astro.site)}><meta name="twitter:card" content="summary_large_image">{noindex&&<meta name="robots" content="noindex,nofollow">}<link rel="icon" href="/favicon.svg">{schema&&<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}</head><body>
<header class="site-header"><div class="wrap nav"><a class="brand" href="/">THE INNER ATLAS</a><nav aria-label="Primary"><a href="/quiet-travel/">Quiet Travel</a><a href="/personal-retreat/">Personal Retreats</a><a href="/places/">Places</a><a href="/between-chapters/">Between Chapters</a></nav><a class="button" href="/build-your-retreat/">Build Your Retreat</a></div></header><main><slot /></main>
<footer class="footer"><div class="wrap footer-grid"><div><a class="brand" href="/">THE INNER ATLAS</a><p>Places, practices, and quiet journeys for the moments between chapters.</p></div><div><strong>Explore</strong><a href="/quiet-travel/">Quiet Travel</a><a href="/personal-retreat/">Personal Retreats</a><a href="/places/dunhuang/">Dunhuang</a></div><div><strong>About</strong><a href="/about/">About</a><a href="/editorial-principles/">Editorial Principles</a><a href="/sources-and-methodology/">Sources</a><a href="/privacy/">Privacy</a><a href="/terms/">Terms</a></div></div></footer>
</body></html>
