---
import '../styles/global.css';
import '../styles/mobile.css';
const { title, description, image='/og.png', type='website', noindex=false, schema, transparentHeader=false, lang='en', alternates=[] } = Astro.props;
const siteOrigin=Astro.site ?? new URL('https://dunhuangwithin.com/');
const canonical=new URL(Astro.url.pathname,siteOrigin);
const fullTitle=title.includes('Dunhuang Within')?title:`${title} | Dunhuang Within`;
const googleSiteVerification=import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const alternateHref=(code:string,fallback:string)=>alternates.find((item:{lang:string,href:string})=>item.lang===code)?.href??fallback;
const home=lang==='de'?'/de/dunhuang/':lang==='fr'?'/fr/dunhuang/':'/';
const nav=lang==='de'
  ? [{label:'Dunhuang',href:'/de/dunhuang/'},{label:'Reiseführer',href:'/de/dunhuang-reisefuehrer/'},{label:'Mogao-Grotten',href:'/de/mogao-grotten/'},{label:'Höhlenbibliothek',href:'/de/hoehle-17-bibliothekshoehle/'}]
  : lang==='fr'
    ? [{label:'Dunhuang',href:'/fr/dunhuang/'},{label:'Guide de voyage',href:'/fr/guide-voyage-dunhuang/'},{label:'Grottes de Mogao',href:'/fr/grottes-de-mogao/'},{label:'Grotte-bibliothèque',href:'/fr/grotte-17-bibliotheque/'}]
    : [{label:'Enter Dunhuang',href:'/places/dunhuang/'},{label:'Trail Map',href:'/dunhuang-map/'},{label:'Paths',href:'/paths/'},{label:'Practices',href:'/practices/'},{label:'Symbols',href:'/symbols/'},{label:'Shop',href:'/objects/'},{label:'Journal',href:'/journal/'},{label:'About Us',href:'/about/'}];
const entitySchema={'@context':'https://schema.org','@graph':[{'@type':'Organization','@id':'https://dunhuangwithin.com/#organization',name:'Dunhuang Within',url:'https://dunhuangwithin.com/'},{'@type':'WebSite','@id':'https://dunhuangwithin.com/#website',url:'https://dunhuangwithin.com/',name:'Dunhuang Within',inLanguage:['en','de','fr']} ]};
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width">
  <title>{fullTitle}</title><meta name="description" content={description}>
  <meta name="robots" content={noindex?'noindex,nofollow':'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'}>
  <link rel="canonical" href={canonical}>
  {alternates.map((item:{lang:string,href:string})=><link rel="alternate" hreflang={item.lang} href={new URL(item.href,siteOrigin)} />)}
  <link rel="sitemap" href="/sitemap-index.xml"><link rel="alternate" type="application/atom+xml" title="Dunhuang Within" href="/feed.xml">
  {googleSiteVerification&&<meta name="google-site-verification" content={googleSiteVerification} />}
  <meta property="og:title" content={fullTitle}><meta property="og:description" content={description}><meta property="og:type" content={type}><meta property="og:url" content={canonical}><meta property="og:site_name" content="Dunhuang Within"><meta property="og:locale" content={lang==='de'?'de_DE':lang==='fr'?'fr_FR':'en_US'}><meta property="og:image" content={new URL(image,siteOrigin)}>
  <meta name="twitter:card" content="summary_large_image"><meta name="twitter:title" content={fullTitle}><meta name="twitter:description" content={description}><meta name="twitter:image" content={new URL(image,siteOrigin)}>
  <link rel="icon" href="/favicon.svg"><script is:inline type="application/ld+json" set:html={JSON.stringify(entitySchema)} />{schema&&<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body>
<header class:list={["site-header",{"on-light":!transparentHeader}]}><div class="wrap nav"><a class="brand" href={home}>DUNHUANG WITHIN</a><nav aria-label="Primary">{nav.map(item=><a href={item.href}>{item.label}</a>)}</nav><div class="language-switcher" aria-label="Language"><a href={alternateHref('en','/')} hreflang="en">EN</a><a href={alternateHref('de','/de/dunhuang/')} hreflang="de">DE</a><a href={alternateHref('fr','/fr/dunhuang/')} hreflang="fr">FR</a></div><details class="mobile-menu"><summary>Menu</summary><nav class="mobile-panel">{nav.map(item=><a href={item.href}>{item.label}</a>)}<a href={alternateHref('en','/')}>English</a><a href={alternateHref('de','/de/dunhuang/')}>Deutsch</a><a href={alternateHref('fr','/fr/dunhuang/')}>Français</a></nav></details></div></header>
<main><slot /></main>
<footer class="footer"><div class="wrap footer-grid"><div><a class="brand" href={home}>DUNHUANG WITHIN</a><p>{lang==='de'?'Dunhuang: Reise, Geschichte, Kunst und Bedeutung.':lang==='fr'?'Dunhuang : voyage, histoire, art et significations.':'Quiet journeys for the space between chapters. Enter Dunhuang. Listen inward.'}</p></div><div><strong>Dunhuang</strong>{nav.slice(0,4).map(item=><a href={item.href}>{item.label}</a>)}</div><div><strong>Languages</strong><a href="/">English</a><a href="/de/dunhuang/">Deutsch</a><a href="/fr/dunhuang/">Français</a></div></div></footer>
<style is:global>.language-switcher{display:flex;gap:.5rem;font-size:.65rem;letter-spacing:.08em}.language-switcher a{text-decoration:none}@media(max-width:900px){.language-switcher{margin-left:auto}}</style>
</body></html>
