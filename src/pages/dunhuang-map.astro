---
import Base from '../layouts/Base.astro';
---
<Base title="Explore the Dunhuang Trail Map" description="Explore interactive illustrated maps of Dunhuang travel places, Buddha traces, and mythic murals.">
<section class="map-hero"><div class="wrap"><nav class="breadcrumbs"><a href="/">Home</a> / Dunhuang Map</nav><p class="eyebrow">Three illustrated trails</p><h1>Follow the traces of Dunhuang.</h1><p class="lede">Choose a map, then select a marked place to reveal its landscape, Buddha image, or mural story.</p></div></section>
<section class="atlas" id="dunhuang-atlas"><div class="wrap"><div class="trail-tabs" role="group" aria-label="Choose a Dunhuang map"><button class="trail-tab active" type="button" data-layer="travel" aria-pressed="true"><span>01</span> Travel Map</button><button class="trail-tab" type="button" data-layer="buddha" aria-pressed="false"><span>02</span> Buddha Traces</button><button class="trail-tab" type="button" data-layer="myth" aria-pressed="false"><span>03</span> Myth & Murals</button></div><div class="map-layout"><div class="map-field" role="group" aria-label="Interactive illustrated map of Dunhuang"><img class="map-base-image" src="/images/dunhuang/travel-map.png" alt="Illustrated travel map of Dunhuang" /><div class="map-vignette"></div><div class="markers"></div><p class="map-hint">Select a numbered point</p></div><aside class="map-detail" aria-live="polite"><div class="detail-image"><img src="/images/dunhuang/mogao-facade.jpg" alt="Mogao Caves facade" /></div><p class="eyebrow detail-kind">Travel · Cultural place</p><h2 class="detail-title">Mogao Caves</h2><p class="detail-meta">Southeast of the Dunhuang oasis</p><p class="detail-copy">A complex of cave sanctuaries preserving a millennium of Buddhist art and cultural exchange.</p><a class="button secondary detail-link" href="/places/dunhuang/mogao-caves/">Enter this story</a></aside></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">How to read the maps</p><div><h2>Place, devotion, and story.</h2><p class="section-copy">Travel Map follows major physical places. Buddha Traces follows images and sites connected with Buddhist art. Myth & Murals follows painted narratives and celestial imagery. The illustrations are exploratory rather than navigation maps.</p></div></div></div></section>
</Base>
<script is:inline>
const maps={
travel:{src:'/images/dunhuang/travel-map.png',alt:'Illustrated travel map of Dunhuang',points:[
{id:'mogao',name:'Mogao Caves',kind:'Travel · Cultural place',meta:'Mogao cave cluster',copy:'A complex of cave sanctuaries preserving a millennium of Buddhist art and cultural exchange.',image:'/images/dunhuang/mogao-facade.jpg',alt:'Mogao Caves facade',link:'/places/dunhuang/mogao-caves/',x:31,y:49},
{id:'crescent',name:'Mingsha Mountain & Crescent Lake',kind:'Travel · Desert and oasis',meta:'South of Dunhuang',copy:'Water and green life held within the dunes: a vivid meeting of exposure, shelter, and return.',image:'/images/dunhuang/desert-oasis.jpg',alt:'Crescent Lake surrounded by dunes',link:'/places/dunhuang/',x:31,y:80},
{id:'yumen',name:'Yumen Pass',kind:'Travel · Ancient frontier',meta:'Northwest of Dunhuang · Image coming soon',copy:'A fortified passage associated with Silk Road movement and the threshold beyond familiar territory.',image:'/images/dunhuang/map-placeholder.jpg',alt:'Dunhuang landscape placeholder',link:'/places/dunhuang/silk-road-crossroads/',x:74,y:40},
{id:'yang',name:'Yang Pass',kind:'Travel · Ancient route',meta:'Southwest route · Image coming soon',copy:'A historic gateway into the western routes, remembered through departure, distance, and crossing.',image:'/images/dunhuang/map-placeholder.jpg',alt:'Dunhuang landscape placeholder',link:'/places/dunhuang/silk-road-crossroads/',x:76,y:45},
{id:'white-horse',name:'White Horse Pagoda',kind:'Travel · Memorial place',meta:'Near Dunhuang city · Image coming soon',copy:'A pagoda connected in local tradition with the journey of the Buddhist translator Kumārajīva.',image:'/images/dunhuang/map-placeholder.jpg',alt:'Dunhuang landscape placeholder',link:'/places/dunhuang/',x:80,y:63},
{id:'museum',name:'Dunhuang Museum',kind:'Travel · Historical collection',meta:'Dunhuang city · Image coming soon',copy:'A place to establish regional and Silk Road context before entering the wider landscape.',image:'/images/dunhuang/map-placeholder.jpg',alt:'Dunhuang landscape placeholder',link:'/sources-and-methodology/',x:81,y:77}]},
buddha:{src:'/images/dunhuang/buddha-map.png',alt:'Illustrated map of Buddhist traces around Dunhuang',points:[
{id:'great-buddha',name:'The Great Buddha',kind:'Buddha Trace · Monumental image',meta:'Mogao Cave 96 tradition',copy:'A monumental Buddha held within the cliff architecture, approached as living religious and cultural heritage.',image:'/images/dunhuang/cave-buddha.jpg',alt:'Monumental Buddha inside a Mogao cave',link:'/places/dunhuang/mogao-caves/',x:34,y:48},
{id:'reclining',name:'The Reclining Buddha',kind:'Buddha Trace · Parinirvana',meta:'Mogao cave sanctuary',copy:'The reclining form evokes the Buddha’s parinirvana and is treated with religious respect, not as a generic wellness image.',image:'/images/dunhuang/reclining-buddha.jpg',alt:'Reclining Buddha inside a painted cave',link:'/brand-story/',x:28,y:52},
{id:'cave-assembly',name:'The Sacred Assembly',kind:'Buddha Trace · Painted sanctuary',meta:'Mogao cave cluster',copy:'Painted and sculpted figures surround the central image, expressing protection, teaching, and devotion.',image:'/images/dunhuang/cave-figures.jpg',alt:'Sacred figures inside a painted cave',link:'/symbols/',x:27,y:50},
{id:'cliff-buddhas',name:'Buddhas of the Cliff',kind:'Buddha Trace · Rock-cut devotion',meta:'Dunhuang cave landscape',copy:'Figures carved into stone make devotion part of the landscape itself: enduring, weathered, and watched over.',image:'/images/dunhuang/cliff-buddhas.jpg',alt:'Buddha figures carved into a cliff',link:'/symbols/',x:21,y:47},
{id:'crescent-buddhist-art',name:'Buddhist Art at the Desert Edge',kind:'Buddha Trace · Landscape and devotion',meta:'Mingsha and cave traditions',copy:'The illustrated trail places devotional images beside the desert threshold, where journey and refuge meet.',image:'/images/dunhuang/cave-buddha.jpg',alt:'Buddha within a dark painted cave',link:'/paths/',x:25,y:72},
{id:'white-horse',name:'White Horse Pagoda',kind:'Buddha Trace · Translation journey',meta:'Near Dunhuang city · Image coming soon',copy:'Local tradition connects the pagoda with the white horse of Kumārajīva, recalling how teachings moved through travel and translation.',image:'/images/dunhuang/map-placeholder.jpg',alt:'Dunhuang landscape placeholder',link:'/places/dunhuang/',x:80,y:64}]},
myth:{src:'/images/dunhuang/myth-map.png',alt:'Illustrated map of Dunhuang myths and mural stories',points:[
{id:'deer',name:'The Nine-Colored Deer',kind:'Myth & Murals · Jataka story',meta:'Associated with Mogao Cave 257',copy:'A painted story of compassion, rescue, betrayal, and moral consequence.',image:'/images/dunhuang/nine-colored-deer.jpg',alt:'Nine-colored deer mural scene',link:'/symbols/',x:53,y:76},
{id:'apsaras',name:'The City of Flying Apsaras',kind:'Myth & Murals · Celestial movement',meta:'Mogao visual world',copy:'Flying figures move through painted space with scarves, music, and weightless motion.',image:'/images/dunhuang/worlds-mural.jpg',alt:'Dunhuang-inspired mural world with flying figures',link:'/brand-story/',x:31,y:32},
{id:'spirit-road',name:'The Road of Spirits and Sutras',kind:'Myth & Murals · Transmission',meta:'Yumen Pass trail',copy:'The illustrated road imagines how teachings, stories, and protective figures traveled with people across the frontier.',image:'/images/dunhuang/desert-caravan.jpg',alt:'Camel caravan crossing desert dunes',link:'/places/dunhuang/silk-road-crossroads/',x:77,y:34},
{id:'water-spirit',name:'Water Spirit at the Oasis',kind:'Myth & Murals · Water and renewal',meta:'Crescent Lake realm',copy:'Water becomes the miraculous counterpoint to desert exposure: a contemporary trail of refuge and return.',image:'/images/dunhuang/desert-oasis.jpg',alt:'Crescent Lake surrounded by dunes',link:'/paths/#oasis-return',x:20,y:38},
{id:'dragon',name:'Dragon of the Danghe River',kind:'Myth & Murals · River guardian',meta:'Danghe River Park',copy:'The illustrated dragon makes flowing water a guardian presence linking the oasis with renewal.',image:'/images/dunhuang/cave-figures.jpg',alt:'Mythic guardian figures in cave art',link:'/symbols/',x:27,y:66},
{id:'guardians',name:'Guardians of the Pass',kind:'Myth & Murals · Protection',meta:'Yumen frontier · Image coming soon',copy:'Guardian imagery marks the boundary between known and unknown worlds.',image:'/images/dunhuang/map-placeholder.jpg',alt:'Dunhuang landscape placeholder',link:'/symbols/',x:78,y:54}]}
};
const root=document.querySelector('#dunhuang-atlas');
const markers=root.querySelector('.markers');
const base=root.querySelector('.map-base-image');
let layer='travel';
function select(item){const image=root.querySelector('.detail-image img');image.onerror=()=>{image.onerror=null;image.src='/images/dunhuang/map-placeholder.jpg';image.alt='Dunhuang landscape placeholder'};image.src=item.image;image.alt=item.alt;root.querySelector('.detail-kind').textContent=item.kind;root.querySelector('.detail-title').textContent=item.name;root.querySelector('.detail-meta').textContent=item.meta;root.querySelector('.detail-copy').textContent=item.copy;root.querySelector('.detail-link').href=item.link;markers.querySelectorAll('button').forEach(button=>button.classList.toggle('selected',button.dataset.id===item.id))}
function draw(){const current=maps[layer];base.src=current.src;base.alt=current.alt;markers.innerHTML='';current.points.forEach((item,index)=>{const button=document.createElement('button');button.type='button';button.className='map-marker';button.dataset.id=item.id;button.style.left=`${item.x}%`;button.style.top=`${item.y}%`;button.setAttribute('aria-label',`Open ${item.name}`);button.innerHTML=`<span>${index+1}</span><strong>${item.name}</strong>`;button.onclick=()=>select(item);markers.appendChild(button)});select(current.points[0])}
root.querySelectorAll('[data-layer]').forEach(button=>button.onclick=()=>{layer=button.dataset.layer;root.querySelectorAll('[data-layer]').forEach(tab=>{const active=tab===button;tab.classList.toggle('active',active);tab.setAttribute('aria-pressed',String(active))});draw()});
draw();
</script>
<style is:global>
.map-hero{padding:11rem 0 5rem;background:linear-gradient(90deg,var(--ink-deep),rgba(23,24,19,.45)),url('/images/dunhuang/travel-map.png') center/cover;color:var(--moonlight)}.atlas{padding:3rem 0 8rem;background:var(--ink-deep);color:var(--moonlight)}.trail-tabs{display:grid;grid-template-columns:repeat(3,1fr);border-block:1px solid rgba(238,233,223,.24);margin-bottom:2rem}.trail-tab{display:flex;gap:1rem;padding:1.3rem;background:transparent;color:inherit;border:0;border-right:1px solid rgba(238,233,223,.24);cursor:pointer;text-transform:uppercase;letter-spacing:.1em}.trail-tab:last-child{border:0}.trail-tab span{color:var(--sand-light)}.trail-tab.active{background:var(--sand-light);color:var(--ink-deep)}.map-layout{display:grid;grid-template-columns:minmax(0,1.65fr) minmax(320px,.65fr);background:#20221d}.map-field{position:relative;overflow:hidden;align-self:start;aspect-ratio:16/9;background:var(--ink-deep)}.map-base-image{position:absolute;inset:0;width:100%;height:100%;object-fit:contain}.map-vignette{position:absolute;inset:0;pointer-events:none;box-shadow:inset 0 0 45px 18px rgba(23,24,19,.32)}.map-hint{position:absolute;left:1rem;bottom:.6rem;padding:.35rem .55rem;background:rgba(23,24,19,.78);font-size:.62rem;letter-spacing:.12em;text-transform:uppercase}.map-marker{position:absolute;z-index:4;transform:translate(-50%,-50%);display:flex;align-items:center;gap:.5rem;padding:0;background:transparent;color:var(--moonlight);border:0;cursor:pointer;text-align:left}.map-marker span{display:grid;place-items:center;width:32px;height:32px;border:2px solid var(--moonlight);border-radius:50%;background:var(--faded-clay);font-size:.68rem;box-shadow:0 2px 10px rgba(23,24,19,.45)}.map-marker strong{max-width:120px;padding:.25rem .4rem;background:rgba(23,24,19,.82);font:500 .7rem var(--sans);opacity:0;transform:translateX(-5px);transition:.2s}.map-marker:hover strong,.map-marker:focus-visible strong,.map-marker.selected strong{opacity:1;transform:none}.map-marker.selected span{background:var(--sand-light);color:var(--ink-deep);box-shadow:0 0 0 7px rgba(238,233,223,.3)}.map-detail{display:flex;flex-direction:column;min-height:100%;padding:2rem;background:#20221d}.detail-image{height:250px;margin:-2rem -2rem 2rem;overflow:hidden}.detail-image img{width:100%;height:100%;object-fit:cover;mask-image:linear-gradient(to bottom,#000 68%,transparent)}.map-detail h2{font-size:clamp(2rem,3vw,3.5rem)}.detail-meta{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-light)}.detail-copy{color:rgba(238,233,223,.75)}.detail-link{margin-top:auto;align-self:flex-start}@media(max-width:1000px){.map-layout{grid-template-columns:1fr}.map-detail{min-height:510px}.trail-tabs{grid-template-columns:1fr}.trail-tab{border-right:0;border-bottom:1px solid rgba(238,233,223,.2)}}@media(max-width:600px){.map-field{aspect-ratio:16/10}.map-marker span{width:27px;height:27px}.map-marker strong{display:none}.map-detail{padding:1.5rem}.detail-image{margin:-1.5rem -1.5rem 2rem}}
.map-marker strong{opacity:1;transform:none}.map-marker{filter:drop-shadow(0 2px 5px rgba(0,0,0,.65))}@media(max-width:600px){.map-marker strong{display:block;max-width:80px;font-size:.58rem}}
</style>
