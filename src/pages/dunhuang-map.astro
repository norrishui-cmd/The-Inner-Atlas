---
import Base from '../layouts/Base.astro';
---
<Base title="Explore the Dunhuang Trail Map" description="Explore an interactive illustrated map of Dunhuang travel places, Buddha traces, and mythic murals.">
<section class="map-hero"><div class="wrap"><nav class="breadcrumbs"><a href="/">Home</a> / Dunhuang Map</nav><p class="eyebrow">An illustrated trail map</p><h1>Follow the traces of Dunhuang.</h1><p class="lede">Move between places, Buddha images, and mural stories. Select a trail, then choose a point on the map.</p></div></section>
<section class="atlas" id="dunhuang-atlas"><div class="wrap"><div class="trail-tabs" role="group" aria-label="Choose a Dunhuang trail"><button class="trail-tab active" type="button" data-layer="travel" aria-pressed="true"><span>01</span> Travel Map</button><button class="trail-tab" type="button" data-layer="buddha" aria-pressed="false"><span>02</span> Buddha Traces</button><button class="trail-tab" type="button" data-layer="myth" aria-pressed="false"><span>03</span> Myth & Murals</button></div><div class="map-layout"><div class="map-field" role="group" aria-label="Illustrated schematic map of Dunhuang"><div class="map-sun"></div><div class="dune dune-one"></div><div class="dune dune-two"></div><div class="dune dune-three"></div><div class="oasis-line"></div><div class="route route-one"></div><div class="route route-two"></div><p class="map-label north">Gobi · North</p><p class="map-label center">Dunhuang Oasis</p><p class="map-label south">Mingsha Dunes · South</p><div class="markers"></div><p class="schematic">Illustrative map · positions are schematic</p></div><aside class="map-detail" aria-live="polite"><div class="detail-image"><img src="/images/dunhuang/mogao-facade.jpg" alt="Mogao Caves facade" /></div><p class="eyebrow detail-kind">Travel · Cultural place</p><h2 class="detail-title">Mogao Caves</h2><p class="detail-meta">Southeast of the Dunhuang oasis</p><p class="detail-copy">A complex of cave sanctuaries preserving a millennium of Buddhist art and cultural exchange.</p><a class="button secondary detail-link" href="/places/dunhuang/mogao-caves/">Enter this story</a></aside></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Three ways of seeing</p><div><h2>One landscape. Many layers of memory.</h2><p class="section-copy">The travel layer follows physical places. Buddha Traces follows images of devotion and protection. Myth & Murals follows stories carried through painting. The latter two are interpretive trails, not claims that the points emit supernatural power.</p></div></div></div></section>
</Base>
<script>
const layers={travel:[{id:'mogao',name:'Mogao Caves',kind:'Travel · Cultural place',meta:'Southeast of the Dunhuang oasis',copy:'A complex of cave sanctuaries preserving a millennium of Buddhist art and cultural exchange.',image:'/images/dunhuang/mogao-facade.jpg',alt:'Mogao Caves facade',link:'/places/dunhuang/mogao-caves/',x:72,y:42},{id:'crescent',name:'Crescent Lake',kind:'Travel · Desert and oasis',meta:'Mingsha Mountain',copy:'Water and green life held within the dunes: a vivid threshold between exposure and return.',image:'/images/dunhuang/desert-oasis.jpg',alt:'Crescent Lake surrounded by dunes',link:'/places/dunhuang/',x:48,y:75},{id:'yumen',name:'Yumen Pass',kind:'Travel · Ancient route',meta:'West of Dunhuang',copy:'A frontier passage associated with movement, distance, and routes beyond familiar worlds.',image:'/images/dunhuang/desert-illustration.jpg',alt:'Illustrated desert landscape and pass',link:'/places/dunhuang/silk-road-crossroads/',x:18,y:34},{id:'yadan',name:'Desert Road',kind:'Travel · Open landscape',meta:'Western desert',copy:'An expansive route where scale, silence, and exposure change the rhythm of attention.',image:'/images/dunhuang/desert-caravan.jpg',alt:'Camel caravan crossing desert dunes',link:'/quiet-travel/desert/',x:27,y:62}],buddha:[{id:'cave96',name:'The Great Buddha',kind:'Buddha Trace · Cave 96',meta:'Mogao Caves',copy:'A monumental image held within the cliff architecture, approached through documented art and living Buddhist heritage.',image:'/images/dunhuang/cave-buddha.jpg',alt:'Monumental Buddha inside a Mogao cave',link:'/places/dunhuang/mogao-caves/',x:73,y:39},{id:'reclining',name:'The Reclining Buddha',kind:'Buddha Trace · Passage and release',meta:'Mogao cave sanctuary',copy:'The reclining form evokes the Buddha’s parinirvana. It is treated as religious heritage, not a generic wellness icon.',image:'/images/dunhuang/reclining-buddha.jpg',alt:'Reclining Buddha inside a painted cave',link:'/brand-story/',x:65,y:56},{id:'cliff',name:'Buddhas of the Cliff',kind:'Buddha Trace · Rock-cut devotion',meta:'Cave landscape',copy:'Figures carved into stone make devotion part of the landscape itself: enduring, weathered, and watched over.',image:'/images/dunhuang/cliff-buddhas.jpg',alt:'Buddha figures carved into a cliff',link:'/symbols/',x:42,y:30},{id:'assembly',name:'The Sacred Assembly',kind:'Buddha Trace · Sanctuary',meta:'Painted cave interior',copy:'Sacred figures surround the central image, expressing protection, teaching, and a world ordered around attention.',image:'/images/dunhuang/cave-figures.jpg',alt:'Sacred figures in a painted cave',link:'/symbols/',x:50,y:68}],myth:[{id:'deer',name:'The Nine-Colored Deer',kind:'Myth & Murals · Jataka story',meta:'Associated with Mogao Cave 257',copy:'A story of compassion, rescue, betrayal, and moral consequence, carried through a recognizable painted narrative.',image:'/images/dunhuang/nine-colored-deer.jpg',alt:'Nine-colored deer mural scene',link:'/symbols/',x:70,y:45},{id:'feitian',name:'Flying Apsaras',kind:'Myth & Murals · Celestial movement',meta:'Dunhuang visual world',copy:'Celestial beings move through painted space with scarves, music, and flight, opening the cave to another realm.',image:'/images/dunhuang/worlds-mural.jpg',alt:'Dunhuang-inspired mural world with flying figures',link:'/brand-story/',x:55,y:25},{id:'guardians',name:'Guardians of the Inner World',kind:'Myth & Murals · Protection',meta:'Cave sanctuary imagery',copy:'Protective figures mark a boundary between ordinary space and the sacred interior.',image:'/images/dunhuang/cave-figures.jpg',alt:'Guardian figures inside a cave sanctuary',link:'/symbols/',x:77,y:65},{id:'caravan',name:'The Road of Stories',kind:'Myth & Murals · Silk Road imagination',meta:'Routes west of the oasis',copy:'Caravans carried more than objects. Stories, images, beliefs, and remembered worlds moved with them.',image:'/images/dunhuang/desert-caravan.jpg',alt:'Camel caravan crossing desert dunes',link:'/places/dunhuang/silk-road-crossroads/',x:25,y:56}]};
const root=document.querySelector<HTMLElement>('#dunhuang-atlas')!,markers=root.querySelector<HTMLElement>('.markers')!;let layer:keyof typeof layers='travel';
function select(item:(typeof layers)[keyof typeof layers][number]){const image=root.querySelector<HTMLImageElement>('.detail-image img')!;image.src=item.image;image.alt=item.alt;root.querySelector<HTMLElement>('.detail-kind')!.textContent=item.kind;root.querySelector<HTMLElement>('.detail-title')!.textContent=item.name;root.querySelector<HTMLElement>('.detail-meta')!.textContent=item.meta;root.querySelector<HTMLElement>('.detail-copy')!.textContent=item.copy;root.querySelector<HTMLAnchorElement>('.detail-link')!.href=item.link;markers.querySelectorAll('button').forEach(button=>button.classList.toggle('selected',(button as HTMLElement).dataset.id===item.id))}
function draw(){markers.innerHTML='';layers[layer].forEach((item,index)=>{const button=document.createElement('button');button.type='button';button.className='map-marker';button.dataset.id=item.id;button.style.left=`${item.x}%`;button.style.top=`${item.y}%`;button.setAttribute('aria-label',`Open ${item.name}`);button.innerHTML=`<span>${index+1}</span><strong>${item.name}</strong>`;button.onclick=()=>select(item);markers.appendChild(button)});select(layers[layer][0]!)}
root.querySelectorAll<HTMLButtonElement>('[data-layer]').forEach(button=>button.onclick=()=>{layer=button.dataset.layer as keyof typeof layers;root.querySelectorAll<HTMLButtonElement>('[data-layer]').forEach(tab=>{const active=tab===button;tab.classList.toggle('active',active);tab.setAttribute('aria-pressed',String(active))});draw()});draw();
</script>
<style>
.map-hero{padding:11rem 0 5rem;background:linear-gradient(90deg,var(--ink-deep),rgba(23,24,19,.56)),url('/images/dunhuang/desert-illustration.jpg') center/cover;color:var(--moonlight)}.atlas{padding:3rem 0 8rem;background:var(--ink-deep);color:var(--moonlight)}.trail-tabs{display:grid;grid-template-columns:repeat(3,1fr);border-block:1px solid rgba(238,233,223,.24);margin-bottom:2rem}.trail-tab{display:flex;gap:1rem;padding:1.3rem;background:transparent;color:inherit;border:0;border-right:1px solid rgba(238,233,223,.24);text-align:left;cursor:pointer;text-transform:uppercase;letter-spacing:.1em}.trail-tab:last-child{border:0}.trail-tab span{color:var(--sand-light)}.trail-tab.active{background:var(--sand-light);color:var(--ink-deep)}.map-layout{display:grid;grid-template-columns:1.55fr .75fr;min-height:680px}.map-field{position:relative;overflow:hidden;min-height:680px;background:radial-gradient(circle at 80% 20%,rgba(215,195,165,.32),transparent 25%),linear-gradient(170deg,#665745,#282b25 58%,#171813);border-right:1px solid rgba(238,233,223,.2)}.map-field:after{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 35%,rgba(23,24,19,.62));pointer-events:none}.map-sun{position:absolute;right:12%;top:11%;width:90px;height:90px;border-radius:50%;background:rgba(215,195,165,.35)}.dune{position:absolute;border-radius:50% 50% 0 0;background:rgba(215,195,165,.12);transform:rotate(-8deg)}.dune-one{left:-12%;right:35%;height:36%;bottom:4%}.dune-two{left:25%;right:-20%;height:42%;bottom:-8%;background:rgba(155,102,83,.2)}.dune-three{left:8%;right:10%;height:20%;bottom:25%;background:rgba(84,105,122,.12)}.oasis-line{position:absolute;left:38%;top:53%;width:22%;height:5%;border-radius:50%;background:rgba(102,117,106,.7)}.route{position:absolute;height:1px;background:rgba(238,233,223,.35);transform-origin:left}.route-one{left:18%;top:38%;width:60%;transform:rotate(18deg)}.route-two{left:25%;top:65%;width:48%;transform:rotate(-32deg)}.map-label{position:absolute;z-index:2;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(238,233,223,.55)}.map-label.north{top:8%;left:6%}.map-label.center{top:50%;left:42%}.map-label.south{bottom:7%;right:7%}.schematic{position:absolute;z-index:2;bottom:1rem;left:1rem;font-size:.62rem;color:rgba(238,233,223,.5)}.map-marker{position:absolute;z-index:4;transform:translate(-50%,-50%);display:flex;align-items:center;gap:.55rem;padding:0;background:transparent;color:var(--moonlight);border:0;cursor:pointer;text-align:left}.map-marker span{display:grid;place-items:center;width:34px;height:34px;border:1px solid var(--sand-light);border-radius:50%;background:var(--ink-deep);font-size:.7rem}.map-marker strong{max-width:115px;font:400 .78rem var(--sans);opacity:0;transform:translateX(-5px);transition:.2s}.map-marker:hover strong,.map-marker:focus-visible strong,.map-marker.selected strong{opacity:1;transform:none}.map-marker.selected span{background:var(--sand-light);color:var(--ink-deep);box-shadow:0 0 0 8px rgba(215,195,165,.14)}.map-detail{display:flex;flex-direction:column;padding:2.5rem;background:#20221d}.detail-image{height:270px;margin:-2.5rem -2.5rem 2.5rem;overflow:hidden}.detail-image img{width:100%;height:100%;object-fit:cover;mask-image:linear-gradient(to bottom,#000 65%,transparent)}.map-detail h2{font-size:clamp(2.3rem,4vw,4rem)}.detail-meta{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sand-light)}.detail-copy{color:rgba(238,233,223,.72)}.detail-link{margin-top:auto;align-self:flex-start}@media(max-width:900px){.map-layout{grid-template-columns:1fr}.map-field{min-height:560px;border-right:0}.map-detail{min-height:540px}.trail-tabs{grid-template-columns:1fr}.trail-tab{border-right:0;border-bottom:1px solid rgba(238,233,223,.2)}}@media(max-width:560px){.map-field{min-height:500px}.map-marker strong{display:none}.map-detail{padding:1.5rem}.detail-image{margin:-1.5rem -1.5rem 2rem}}
</style>
