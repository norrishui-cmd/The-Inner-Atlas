---
import Base from '../layouts/Base.astro';
---
<Base transparentHeader title="Find Your Dunhuang Path" description="A private five-step experience connecting what you are moving through with a Dunhuang-inspired path and practical retreat."><section class="hero builder-hero"><div class="wrap builder"><p class="eyebrow">A modern inner journey through Dunhuang</p><h1>Find Your Path</h1><p class="lede">Five quiet choices. A Dunhuang-inspired path. A practical way to begin where you are.</p><div class="progress" aria-hidden="true"><span style="width:20%"></span></div><div id="path-builder"></div></div></section></Base>
<script>
import {recommend,schedule,type Answers} from '../lib/retreat-engine'; import {track} from '../lib/analytics';
const steps=[
  ['state','What are you moving through?',['Too much noise','Uncertainty','A chapter ending','Feeling disconnected','Fear of change','A search for meaning']],
  ['intention','What are you looking for?',['Silence','Clarity','Courage','Renewal','Release','Purpose']],
  ['landscape','Which landscape calls to you?',['Desert','Cave','Oasis','Road','Moonlit sky','Ancient walls']],
  ['duration','How much space do you have?',['10 minutes','2 hours','Half a day','One day','A weekend','Seven days']],
  ['practice','How would you like to begin?',['Read','Reflect','Walk','Disconnect','Write','Sit in silence']]
] as const;
const away:Record<string,string>={'Too much noise':'Constant noise','Uncertainty':'Decision fatigue','A chapter ending':'A difficult chapter','Feeling disconnected':'Other people’s expectations','Fear of change':'Decision fatigue','A search for meaning':'A difficult chapter'};
const need:Record<string,string>={Silence:'Silence',Clarity:'Clarity',Courage:'Courage',Renewal:'Renewal',Release:'Rest',Purpose:'Meaning'};
const land:Record<string,string>={Desert:'Desert',Cave:'Ancient place',Oasis:'Forest',Road:'Open road','Moonlit sky':'Mountain','Ancient walls':'Ancient place'};
const time:Record<string,string>={'10 minutes':'2 hours','2 hours':'2 hours','Half a day':'Half a day','One day':'1 day','A weekend':'A weekend','Seven days':'7 days'};
const pathNames:Record<string,string>={'desert-crossing':'The Desert Crossing','quiet-return':'The Oasis Return',clearing:'The Silk Road Path',threshold:'The Quiet Threshold','open-road':'The Silk Road Path','deep-rest':'The Oasis Return','ancient-pause':'The Hidden Cave','digital-sunset':'The Hidden Cave'};
const root=document.querySelector<HTMLElement>('#path-builder')!;let index=0;const values:Record<string,string>={};track('builder_start');
function show(){const [key,question,options]=steps[index]!;root.innerHTML=`<p class="eyebrow">Step ${index+1} of 5</p><h2>${question}</h2><div class="choices">${options.map(option=>`<button class="choice" data-value="${option}">${option}</button>`).join('')}</div>${index?'<button class="button secondary" data-back>Back</button>':''}`;document.querySelector('.progress span')?.setAttribute('style',`width:${(index+1)*20}%`);root.querySelectorAll<HTMLButtonElement>('[data-value]').forEach(button=>button.onclick=()=>{values[key]=button.dataset.value!;track('builder_step',{step:index+1});if(index<4){index++;show()}else result()});root.querySelector<HTMLButtonElement>('[data-back]')?.addEventListener('click',()=>{index--;show()})}
function result(){const answers:Answers={away:away[values.state!]!,seek:need[values.intention!]!,landscape:land[values.landscape!]!,duration:time[values.duration!]!,location:'At home'};const archetype=recommend(answers);const plan=schedule(answers.duration);const path=pathNames[archetype.id]??archetype.name;history.replaceState(null,'',`?path=${archetype.id}`);track('builder_complete',{archetype:archetype.id});root.innerHTML=`<div class="result active"><p class="eyebrow">Your Dunhuang Path</p><h1>${path}</h1><p class="lede">${archetype.tagline}</p><h2>Why this path</h2><p>You are moving through ${values.state!.toLowerCase()}, seeking ${values.intention!.toLowerCase()}, and drawn toward the ${values.landscape!.toLowerCase()}. This path brings those signals together without claiming an ancient doctrine or guaranteed outcome.</p><h2>Your first practice</h2><p>Begin with this intention: ${values.practice}. Protect ${values.duration!.toLowerCase()} from optional input and let the practice be complete without forcing an answer.</p><h2>Reflection questions</h2><ol>${archetype.reflectionQuestions.map(question=>`<li>${question}</li>`).join('')}</ol><h2>Your beginning</h2><div class="schedule">${plan.map(item=>`<h3>${item.time} — ${item.title}</h3><p>${item.detail}</p>`).join('')}</div><h2>Continue into Dunhuang</h2><p><a href="/places/dunhuang/">Enter the story of a place between worlds →</a></p><p><a href="/symbols/">Explore the symbols carried across time →</a></p><button class="button secondary" data-restart>Begin again</button></div>`;root.querySelector('[data-restart]')?.addEventListener('click',()=>{index=0;show()})}
show();
</script>
