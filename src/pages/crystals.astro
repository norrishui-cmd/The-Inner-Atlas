---
import CollectionLanding from '../components/CollectionLanding.astro';
const questions=[
  {q:'Do crystals have healing energy?',a:'Some spiritual traditions and individuals attribute meanings to crystals, but Dunhuang Within does not present crystals as medical treatment or measurable energy technology.'},
  {q:'How do I choose a crystal by intention?',a:'Start with the quality you want to practice, then choose a color, weight and texture that reliably brings that intention to mind.'},
  {q:'Are crystals part of an ancient Dunhuang system?',a:'Dunhuang Within does not claim an ancient Dunhuang crystal-healing doctrine. Our pairings are contemporary design and reflection frameworks.'},
  {q:'How can I use a crystal in meditation?',a:'Place it where it can anchor attention, hold it gently, and return to breath or a chosen phrase when the mind wanders.'}
];
---
<CollectionLanding title="Dunhuang Intention Crystals" description="Explore future Dunhuang-inspired crystals and stone objects for meditation, courage, clarity, renewal and direction—without unsupported healing claims." eyebrow="Future collection · crystals" h1="Choose a stone. Practice the intention." lede="Crystals and mineral objects connected to Dunhuang's desert palette and four modern paths, created as anchors for attention rather than promises of cure." image="/images/dunhuang/desert-oasis.jpg" intention={{title:'Material attention, not magical certainty.',copy:'Color, temperature, weight and texture can give attention somewhere to return. The practice you repeat gives the object its personal role.'}} meaning="Dunhuang was shaped by stone, sand, pigment and movement across landscapes. Our crystal pairings are contemporary reflections on those material qualities, not claims of an ancient local healing system." materials="Every future stone will be identified as accurately as possible, including treatments or synthetic status where relevant. Sourcing and durability will be considered alongside appearance." ritual="Hold the stone for three breaths. Silently name the intention. Then choose one observable action that can express it today." questions={questions} source="crystals-waitlist" />
