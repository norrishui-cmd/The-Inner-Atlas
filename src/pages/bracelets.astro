---
import CollectionLanding from '../components/CollectionLanding.astro';
const questions=[
  {q:'What does a spiritual bracelet do?',a:'It can act as a tactile reminder of an intention or practice. Dunhuang Within does not claim that a bracelet treats disease, guarantees luck or changes external events.'},
  {q:'Which wrist should I wear it on?',a:'There is no universal Dunhuang rule. Choose the wrist where the bracelet is comfortable and likely to bring your chosen practice back to attention.'},
  {q:'Are these Buddhist prayer beads?',a:'Not unless a specific product is accurately designed and described for that practice. Inspired jewelry and formal Buddhist prayer beads are not interchangeable.'},
  {q:'How do I choose a bracelet?',a:'Begin with the quality you want to practice—courage, clarity, renewal or direction—then consider material, fit, sourcing and cultural meaning.'}
];
---
<CollectionLanding title="Dunhuang Spiritual Bracelets" description="Explore future Dunhuang-inspired spiritual bracelets and crystal bracelets for courage, clarity, renewal and direction, grounded in cultural context and daily practice." eyebrow="Future collection · bracelets" h1="An intention held at the wrist." lede="Dunhuang-inspired bracelets designed to bring courage, clarity, renewal or direction back into the gestures of an ordinary day." image="/images/dunhuang/desert-caravan.jpg" intention={{title:'Touch becomes a return.',copy:'A bracelet repeatedly meets the hand. That ordinary contact can interrupt automatic movement and return attention to one chosen quality.'}} meaning="Forms and colors may draw from mural rhythm, manuscript bindings, desert mineral tones and the contrast between passage and oasis. Each design will distinguish documented source from contemporary interpretation." materials="Natural stones, mineral-colored beads, metal, cord and responsibly sourced components are being evaluated for durability, touch and traceability—not for unsupported healing claims." ritual="When your hand meets the bracelet, take one unforced breath. Name the quality you chose. Let the next action express it." questions={questions} source="bracelets-waitlist" />
