---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
type HubLink=[label:string,href:string];
type HubGroup={title:string;links:HubLink[]};
const clusters:HubGroup[]=[
 {title:'Choose by form',links:[['Spiritual Bracelets','/bracelets/'],['Intention Necklaces','/necklaces/'],['Meditation Crystals','/crystals/']]},
 {title:'Understand the symbol',links:[['Nine-Colored Deer Meaning','/places/dunhuang/nine-colored-deer-meaning/'],['Three Hares Meaning','/places/dunhuang/three-hares-meaning/'],['Dunhuang Caisson Ceilings','/places/dunhuang/caisson-ceiling-meaning/'],['Dunhuang Mandala Meaning','/places/dunhuang/dunhuang-mandala-meaning/'],['Dunhuang Colors','/places/dunhuang/dunhuang-colors-meaning/'],['Dunhuang Feitian Meaning','/places/dunhuang/feitian-spiritual-meaning/'],['Dunhuang Lotus Symbol','/places/dunhuang/dunhuang-lotus-symbol/'],['Lotus Jewelry Meaning','/places/dunhuang/lotus-jewelry-meaning/'],['All Dunhuang Symbols','/symbols/']]},
 {title:'Choose responsibly',links:[['Protection Symbols in Dunhuang Art','/places/dunhuang/protection-symbols-dunhuang-art/'],['Buddhist Jewelry Meaning','/places/dunhuang/buddhist-jewelry-meaning/'],['Meditation Necklace Meaning','/places/dunhuang/meditation-necklace-meaning/'],['Set an Intention for a Bracelet','/places/dunhuang/how-to-set-an-intention-bracelet/'],['Spiritual Bracelet vs Mala','/places/dunhuang/spiritual-bracelet-vs-mala/'],['Buddhist-Inspired Jewelry Guide','/places/dunhuang/responsible-buddhist-jewelry/'],['Spiritual Jewelry Gift Guide','/places/dunhuang/jewelry-gift-guide/'],['Crystal Bracelet Care','/places/dunhuang/cleanse-crystal-bracelet/']]}
];
const siteOrigin=Astro.site ?? new URL('https://dunhuangwithin.com/');
const schema={'@context':'https://schema.org','@type':'CollectionPage',name:'Dunhuang Spiritual Jewelry',description:'The complete Dunhuang Within guide to culturally grounded spiritual bracelets, intention necklaces and crystals.',url:'https://dunhuangwithin.com/spiritual-jewelry/',mainEntity:{'@type':'ItemList',itemListElement:clusters.flatMap(group=>group.links).map((link,index)=>({'@type':'ListItem',position:index+1,name:link[0],url:new URL(link[1],siteOrigin).href}))}};
---
<Base title="Dunhuang Spiritual Jewelry Guide" description="Explore Dunhuang-inspired spiritual bracelets, intention necklaces, crystals, Feitian and lotus meanings, responsible buying guides and future collections." schema={schema}>
<section class="jewelry-hub-hero"><div class="wrap"><p class="eyebrow">Culture · symbol · intention · object</p><h1>Dunhuang Spiritual Jewelry</h1><p class="lede">A complete path from documented Dunhuang culture to bracelets, necklaces and crystals designed as daily anchors for intention.</p><div class="actions"><a class="button" href="/objects/" data-seo-event="category_click">Explore Future Collections</a><a class="button secondary" href="/find-your-path/" data-seo-event="find_path_click">Find Your Path</a></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Why Dunhuang Within</p><div><h2>Meaning before merchandise.</h2><p class="lede">We identify the artwork, landscape or manuscript behind a symbol; separate historical context from contemporary reflection; and connect the object with a repeatable practice.</p></div></div>{clusters.map(group=><section class="hub-group"><h2>{group.title}</h2><div class="hub-links">{group.links.map(link=><a href={link[1]} data-seo-event="category_click"><strong>{link[0]}</strong><span>Explore →</span></a>)}</div></section>)}</div></section>
<section class="section dark"><div class="wrap"><p class="eyebrow">Our standard</p><h2>Spiritual language without false certainty.</h2><p class="lede">We do not promise medical healing, guaranteed fortune, measurable “Dunhuang energy,” or undocumented blessings. The power we speak about is the human capacity to return to courage, clarity, compassion and direction through attention and practice.</p><a class="button" href="/places/dunhuang/spiritual-jewelry/">Read Our Approach</a></div></section>
<section class="section"><div class="wrap"><Newsletter heading="Enter the first release" copy="Receive the cultural source, design story and first access to Dunhuang Within jewelry and crystals." buttonLabel="Join the Jewelry List" source="spiritual-jewelry-hub" /></div></section>
</Base>
<style>.jewelry-hub-hero{min-height:78vh;display:flex;align-items:end;padding:10rem 0 6rem;color:var(--moonlight);background:linear-gradient(90deg,rgba(15,16,12,.95),rgba(15,16,12,.4)),url('/images/dunhuang/reclining-buddha.jpg') center/cover}.hub-group{margin-top:5rem}.hub-links{display:grid;grid-template-columns:repeat(2,1fr);border-top:1px solid var(--line)}.hub-links a{display:flex;justify-content:space-between;padding:1.5rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);text-decoration:none}@media(max-width:700px){.jewelry-hub-hero{min-height:68vh;padding:8rem 0 4rem}.hub-links{grid-template-columns:1fr}.hub-links a{border-right:0}}</style>
