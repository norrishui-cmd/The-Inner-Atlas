---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import AmbientVideo from '../components/AmbientVideo.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('articles', ({ data }) => data.status === 'published');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const segments = item.id.split('/');
const breadcrumbs = segments.map((segment: string, index: number) => ({
  label: segment.replaceAll('-', ' '),
  href: `/${segments.slice(0, index + 1).join('/')}/`,
  isLast: index === segments.length - 1,
}));
const sources = item.data.sources ?? [];
const faq = item.data.faq ?? [];
const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const relatedIds = item.data.relatedContent ?? [];
const relatedItems = relatedIds.map((id:string)=>allArticles.find(article=>article.id===id)).filter(Boolean).slice(0,4);
const isJewelryTopic = item.id.startsWith('places/dunhuang/') && ['spiritual-jewelry','feitian-spiritual-meaning','lotus-jewelry-meaning','crystal-bracelet-intention','spiritual-bracelet-vs-mala','responsible-buddhist-jewelry','jewelry-gift-guide','cleanse-crystal-bracelet','nine-colored-deer-meaning','three-hares-meaning','caisson-ceiling-meaning','dunhuang-colors-meaning','dunhuang-lotus-symbol','protection-symbols-dunhuang-art','buddhist-jewelry-meaning','how-to-set-an-intention-bracelet','meditation-necklace-meaning','dunhuang-mandala-meaning'].some(topic=>item.id.endsWith(topic));
const siteOrigin=Astro.site ?? new URL('https://dunhuangwithin.com/');
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const heroImageUrl = item.data.heroImage ? new URL(item.data.heroImage, siteOrigin).href : undefined;
const schema = {
  '@context': 'https://schema.org',
  '@graph': [{
    '@type': item.data.contentType === 'place' ? 'TouristAttraction' : 'Article',
    headline: item.data.title,
    description: item.data.description,
    datePublished: item.data.publishedAt.toISOString(),
    dateModified: (item.data.updatedAt ?? item.data.publishedAt).toISOString(),
    author: { '@type':'Organization','@id':'https://dunhuangwithin.com/#editorial-team',name:'Dunhuang Within Editorial Team',url:'https://dunhuangwithin.com/authors/dunhuang-within-editorial-team/' },
    publisher: { '@id': 'https://dunhuangwithin.com/#organization' },
    mainEntityOfPage: canonicalUrl,
    ...(heroImageUrl?{image:{'@type':'ImageObject',url:heroImageUrl,width:item.data.heroWidth,height:item.data.heroHeight,caption:item.data.heroCaption??item.data.heroAlt}}:{}),
  },{
    '@type':'BreadcrumbList',itemListElement:[
      {'@type':'ListItem',position:1,name:'Home',item:'https://dunhuangwithin.com/'},
      ...breadcrumbs.map((crumb,index)=>({'@type':'ListItem',position:index+2,name:crumb.label,item:new URL(crumb.href,siteOrigin).href}))
    ]
  },...(faq.length?[{'@type':'FAQPage','@id':`${canonicalUrl}#faq`,mainEntity:faq.map(entry=>({'@type':'Question',name:entry.question,acceptedAnswer:{'@type':'Answer',text:entry.answer}}))}]:[])]
};
---

<Base
  title={item.data.seoTitle ?? item.data.title}
  description={item.data.seoDescription ?? item.data.description}
  image={item.data.heroImage ?? '/og.png'}
  noindex={item.data.noindex}
  type="article"
  schema={schema}
>
  <article class="article">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      {breadcrumbs.map((crumb) => <span> / <a href={crumb.href} aria-current={crumb.isLast ? 'page' : undefined}>{crumb.label}</a></span>)}
    </nav>
    <p class="eyebrow">{item.data.cluster.replaceAll('-', ' ')}</p>
    <h1>{item.data.title}</h1>
    <p class="lede">{item.data.description}</p>
    <p class="article-byline">By <a href="/authors/dunhuang-within-editorial-team/">Dunhuang Within Editorial Team</a> · Published <time datetime={item.data.publishedAt.toISOString()}>{item.data.publishedAt.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</time>{item.data.updatedAt&&<> · Updated <time datetime={item.data.updatedAt.toISOString()}>{item.data.updatedAt.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}</time></>}</p>
    {item.data.heroImage&&item.data.heroAlt&&<figure class="article-hero"><img src={item.data.heroImage} alt={item.data.heroAlt} width={item.data.heroWidth} height={item.data.heroHeight} loading="eager" fetchpriority="high" decoding="async" />{item.data.heroCaption&&<figcaption>{item.data.heroCaption}</figcaption>}</figure>}
      {(item.data.videoId || item.data.videoSrc) && <AmbientVideo videoId={item.data.videoId} src={item.data.videoSrc} title={item.data.videoTitle ?? 'A quiet visual'} eyebrow={item.data.videoEyebrow} copy={item.data.videoCopy} />}
      <Content />
    {faq.length > 0 && <section class="article-faq" id="questions"><h2>Questions people ask</h2>{faq.map(entry=><details><summary>{entry.question}</summary><p>{entry.answer}</p></details>)}</section>}
    {sources.length > 0 && (
      <section>
        <h2>Sources & further reading</h2>
        <ul>{sources.map((source) => <li><a href={source.url} rel="noopener">{source.title}</a> — {source.publisher}</li>)}</ul>
      </section>
    )}
    {relatedItems.length > 0 && <section><h2>Continue exploring</h2><div class="related-grid">{relatedItems.map((related:any)=><a href={`/${related.id}/`} data-seo-event="related_content_click"><strong>{related.data.title}</strong><span>{related.data.description}</span></a>)}</div></section>}
    <hr />
    <p><a href={isJewelryTopic?'/objects/':'/build-your-retreat/'}>{isJewelryTopic?'Explore Dunhuang jewelry and objects of intention →':'Build a personal retreat around what you need now →'}</a></p>
  </article>
  <section class="section"><div class="wrap"><Newsletter compact /></div></section>
</Base>
<style>.article-byline{font-size:.78rem;color:var(--ink-muted);margin-bottom:3rem}.article-hero{margin:0 0 4rem}.article-hero img{width:100%;height:auto;max-height:680px;object-fit:cover}.article-hero figcaption{margin-top:.7rem;font-size:.72rem;color:var(--ink-muted)}.article-faq{margin-top:4rem}.article-faq details{padding:1.2rem 0;border-bottom:1px solid var(--line)}.article-faq summary{cursor:pointer;font:400 1.2rem var(--serif)}.article-faq details p{margin:1rem 0 0}.related-grid{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line)}.related-grid a{display:flex;flex-direction:column;gap:.5rem;padding:1.5rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);text-decoration:none}.related-grid span{font-size:.85rem;color:var(--ink-muted)}@media(max-width:650px){.related-grid{grid-template-columns:1fr}.related-grid a{border-right:0}}</style>
