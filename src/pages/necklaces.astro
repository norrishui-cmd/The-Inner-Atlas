---
import CollectionLanding from '../components/CollectionLanding.astro';
const questions=[
  {q:'What is an intention necklace?',a:'It is a necklace chosen to represent a personal commitment, question or quality. Its value comes from meaning and repeated attention rather than a guaranteed effect.'},
  {q:'What Dunhuang symbols may appear?',a:'Future designs may draw from Feitian movement, lotus imagery, cave geometry, manuscript forms and Silk Road landscapes, with the source explained for each piece.'},
  {q:'Is a Buddha necklace automatically blessed?',a:'No. A religious image, retail description and formal blessing are different things. Dunhuang Within will never describe an item as blessed without a real documented process.'},
  {q:'How should I choose a pendant?',a:'Choose a symbol whose documented context and contemporary intention both matter to you, then consider scale, material, chain length and how often you will wear it.'}
];
---
<CollectionLanding title="Dunhuang Necklaces & Intention Pendants" description="Discover future Dunhuang-inspired necklaces and symbolic pendants shaped by Feitian, lotus, cave and Silk Road imagery for mindful daily wear." eyebrow="Future collection · necklaces" h1="Carry one symbol close." lede="Necklaces and pendants that translate Dunhuang's visual memory into a private reminder of movement, compassion, clarity and return." image="/images/dunhuang/worlds-mural.jpg" intention={{title:'A symbol near the center.',copy:'A pendant can hold one deliberate image close to the body. The practice is not possession of the symbol, but remembering what you asked it to represent.'}} meaning="The collection will begin with documented Dunhuang imagery. Feitian, lotus and cave-derived forms will be contextualized rather than detached from their Buddhist and historical settings." materials="Metal, stone, cord and mineral-color details are under consideration. Material descriptions will be precise, and religious significance will not be invented for marketing." ritual="Before putting on the necklace, name one action that would embody its intention today. At night, ask whether the symbol changed what you noticed." questions={questions} source="necklaces-waitlist" />
