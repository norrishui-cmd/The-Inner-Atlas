---
import Base from '../layouts/Base.astro'; import Newsletter from '../components/Newsletter.astro'; import { getCollection } from 'astro:content';
const featured=(await getCollection('articles',({data})=>data.status==='published'&&data.featured)).slice(0,3);
---
<Base title="The Inner Atlas — Quiet Travel & Personal Retreats" description="Step away from noise with quiet travel guides, personal retreat plans, and meaningful places including Dunhuang.">
<section class="hero"><div class="wrap"><p class="eyebrow">For people between chapters</p><h1>Find space between the noise and what comes next.</h1><p class="lede">The Inner Atlas explores quiet travel, personal retreats, and places that help us see our lives from a different distance.</p><div class="actions"><a class="button" href="/build-your-retreat/">Build Your Personal Retreat</a><a class="button secondary" href="/quiet-travel/">Explore Quiet Journeys</a></div></div></section>
<section class="section"><div class="wrap"><p class="eyebrow">Where are you now?</p><h2>A pause can begin before you know the answer.</h2><div class="grid"><a class="card" href="/between-chapters/feeling-lost/"><h3>I feel between chapters</h3><p>Make room for uncertainty without forcing a breakthrough.</p></a><a class="card" href="/digital-detox/"><h3>I need less input</h3><p>Create a humane boundary around screens and constant information.</p></a><a class="card" href="/personal-retreat/"><h3>I need space to think</h3><p>Plan a self-directed retreat that fits the time and place you have.</p></a></div></div></section>
<section class="section tint"><div class="wrap"><p class="eyebrow">A gentler way to travel</p><h2>Quiet travel begins with attention, not distance.</h2><p class="lede">It favors fewer transitions, spacious schedules, local context, and time without constant documentation. You can practice it across an ocean—or an hour from home.</p><a class="button secondary" href="/quiet-travel/what-is-quiet-travel/">What is quiet travel?</a></div></section>
<section class="section"><div class="wrap"><div class="grid"><div><p class="eyebrow">Free planning tool</p><h2>Build a retreat around your real life.</h2><p>Five simple choices become a practical, timed plan—without accounts, diagnoses, or an AI API.</p><a class="button" href="/build-your-retreat/">Start the builder</a></div><div class="card"><p class="eyebrow">Featured place</p><h2>Dunhuang</h2><p>An oasis at a historic crossroads, where desert scale and layered cultural history offer a different distance from everyday noise.</p><a href="/places/dunhuang/">Discover a place between worlds →</a></div><div class="card"><p class="eyebrow">Quietness framework</p><h3>Five dimensions of a quieter journey</h3><p>Environmental calm, digital distance, spacious time, intentional solitude, and cultural depth.</p></div></div></div></section>
<section class="section tint"><div class="wrap"><p class="eyebrow">Field notes</p><h2>Guides for the next small step</h2><div class="grid">{featured.map(a=><a class="card" href={`/${a.id}/`}><h3>{a.data.title}</h3><p>{a.data.description}</p></a>)}</div></div></section>
<section class="section"><div class="wrap"><Newsletter /></div></section>
</Base>
