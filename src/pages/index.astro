---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
const featured=(await getCollection('articles',({data})=>data.status==='published'&&data.featured)).slice(0,3);
---
<Base transparentHeader title="The Inner Atlas — Quiet Travel & Personal Retreats" description="Step away from noise with quiet travel guides, personal retreat plans, and meaningful places including Dunhuang.">
<section class="hero"><div class="wrap"><p class="eyebrow">For the space between chapters</p><h1>Find space between the noise and what comes next.</h1><p class="lede">Explore quiet journeys, create a personal retreat, and discover places that offer a different way of seeing.</p><div class="actions"><a class="button" href="/build-your-retreat/">Build Your Retreat</a><a class="button secondary" href="/quiet-travel/">Explore Quiet Travel</a></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Begin where you are</p><div><h2>Where are you right now?</h2><p class="section-copy">You do not need a destination—or an answer—to begin. Choose the feeling closest to this moment.</p></div></div><div class="state-grid"><a class="state-tile" href="/quiet-travel/for-digital-overload/"><span>01</span><strong>I feel overwhelmed</strong></a><a class="state-tile" href="/digital-detox/"><span>02</span><strong>I need distance from screens</strong></a><a class="state-tile" href="/between-chapters/"><span>03</span><strong>I’m between chapters</strong></a><a class="state-tile" href="/between-chapters/need-space-to-think/"><span>04</span><strong>I need space to think</strong></a><a class="state-tile" href="/personal-retreat/questions-for-reflection/"><span>05</span><strong>I’m looking for meaning</strong></a><a class="state-tile" href="/personal-retreat/"><span>06</span><strong>I don’t know yet</strong></a></div></div></section>
<section class="manifesto"><div class="wrap"><p class="eyebrow">A quiet travel manifesto</p><h2>Not every journey is about seeing more.</h2><div class="manifesto-lines"><span>Hear less.</span><span>Carry less.</span><span>Leave input behind.</span><span>Let distance change perspective.</span></div></div></section>
<section class="section dark"><div class="wrap builder-feature"><div><p class="eyebrow">A real retreat, shaped around you</p><h2>Create a retreat around the space you actually have.</h2><p class="lede">Two hours. One day. A weekend. Start where you are.</p><div class="actions"><a class="button" href="/build-your-retreat/">Build Your Personal Retreat</a></div></div><div class="builder-preview" aria-label="Example retreat result"><div class="preview-row"><span>Time</span><strong>1 day</strong></div><div class="preview-row"><span>Need</span><strong>Clarity</strong></div><div class="preview-row"><span>Landscape</span><strong>Desert</strong></div><div class="preview-row"><span>Result</span><strong>The Desert Crossing</strong></div></div></div></section>
<section class="chapters"><div class="wrap"><article class="chapter"><div><span class="chapter-no">I</span><h2>Leave the Noise</h2><p>Step beyond the stream of alerts, opinions, and unfinished demands.</p></div><div class="chapter-art" aria-hidden="true"></div></article><article class="chapter"><div><span class="chapter-no">II</span><h2>Create Distance</h2><p>Not escape. Enough room to see the pattern without standing inside it.</p></div><div class="chapter-art" aria-hidden="true"></div></article><article class="chapter"><div><span class="chapter-no">III</span><h2>Listen Again</h2><p>Notice what remains when the world stops supplying the next thought.</p></div><div class="chapter-art" aria-hidden="true"></div></article><article class="chapter"><div><span class="chapter-no">IV</span><h2>Cross Into What Comes Next</h2><p>Return with one honest step, not a promise to reinvent everything.</p></div><div class="chapter-art" aria-hidden="true"></div></article></div></section>
<section class="dunhuang"><div class="wrap"><p class="coordinates">40.14° N, 94.66° E</p><h2>Dunhuang</h2><h3>A Place Between Worlds</h3><p class="lede">At the edge of the desert, routes, languages, beliefs, and lives once crossed. For those standing between who they were and what comes next.</p><div class="actions"><a class="button" href="/places/dunhuang/">Enter Dunhuang</a></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Explore by need</p><h2>The journey begins with what you need less of—and what you need room for.</h2></div><div class="needs-list"><a class="need-row" href="/quiet-travel/"><strong>Silence</strong><span>When the world feels too loud</span><span>→</span></a><a class="need-row" href="/between-chapters/need-space-to-think/"><strong>Clarity</strong><span>When everything feels possible and nothing feels clear</span><span>→</span></a><a class="need-row" href="/personal-retreat/"><strong>Distance</strong><span>When you need to step outside the pattern</span><span>→</span></a><a class="need-row" href="/between-chapters/"><strong>Renewal</strong><span>When the old chapter has ended</span><span>→</span></a><a class="need-row" href="/personal-retreat/questions-for-reflection/"><strong>Meaning</strong><span>When success no longer answers the question</span><span>→</span></a></div></div></section>
<section class="section tint"><div class="wrap"><p class="eyebrow">Stories for quieter attention</p><h2>Field notes from the inner atlas.</h2><div class="editorial-grid">{featured.map((a,i)=><a class:list={["story",{lead:i===0}]} href={`/${a.id}/`}><span class="story-meta">{a.data.cluster.replaceAll('-',' ')} · {i===0?'7':'5'} min</span><h3>{a.data.title}</h3><p>{a.data.description}</p></a>)}</div></div></section>
<section class="section"><div class="wrap"><Newsletter /></div></section>
</Base>
