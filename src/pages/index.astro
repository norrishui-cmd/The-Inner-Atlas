---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
const featured=(await getCollection('articles',({data})=>data.status==='published'&&data.featured)).slice(0,3);
---
<Base transparentHeader title="Dunhuang Within — A Modern Inner Journey Through Dunhuang" description="Explore Dunhuang through silence, crossing, memory, ancient symbols, and modern practices for the space between chapters.">
<section class="hero hero-dunhuang"><div class="wrap"><p class="eyebrow">A Place Between Worlds</p><p class="hero-brand">Dunhuang Within</p><h1>Some journeys begin when the old path no longer fits.</h1><p class="lede">Explore Dunhuang through silence, crossing, memory, ancient symbols, and modern practices for the space between chapters.</p><div class="actions"><a class="button" href="/find-your-path/">Find Your Path</a><a class="button secondary" href="/places/dunhuang/">Enter Dunhuang</a></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Why are you here?</p><div><h2>What are you moving through?</h2><p class="section-copy">Begin with the moment you are in. A path through Dunhuang can start with noise, uncertainty, a chapter ending, or a search for meaning.</p></div></div><div class="state-grid"><a class="state-tile" href="/paths/#hidden-cave"><span>01</span><strong>Too much noise</strong></a><a class="state-tile" href="/paths/#quiet-threshold"><span>02</span><strong>A chapter ending</strong></a><a class="state-tile" href="/paths/#desert-crossing"><span>03</span><strong>Uncertainty</strong></a><a class="state-tile" href="/paths/#silk-road"><span>04</span><strong>Loss of direction</strong></a><a class="state-tile" href="/practices/"><span>05</span><strong>Need for distance</strong></a><a class="state-tile" href="/journal/"><span>06</span><strong>Search for meaning</strong></a></div></div></section>
<section class="dunhuang dunhuang-origin"><div class="wrap origin-grid"><div><p class="eyebrow">40.14° N, 94.66° E</p><h2>Dunhuang</h2></div><div><h3>At the edge of the desert, worlds once met.</h3><p class="lede">Desert and oasis. Routes and caves. Manuscripts, languages, beliefs, and lives crossing at the edge of uncertainty.</p><p>Dunhuang Within begins with documented cultural history, then clearly separates the modern reflections we draw from it.</p><div class="actions"><a class="button" href="/places/dunhuang/">Enter Dunhuang</a></div></div></div></section>
<section class="manifesto"><div class="wrap"><p class="eyebrow">Paths</p><h2>Find the path that meets you where you are.</h2><div class="manifesto-lines"><a href="/paths/#desert-crossing">The Desert Crossing</a><a href="/paths/#hidden-cave">The Hidden Cave</a><a href="/paths/#oasis-return">The Oasis Return</a><a href="/paths/#silk-road">The Silk Road Path</a></div><div class="actions"><a class="button secondary" href="/paths/">Explore All Paths</a></div></div></section>
<section class="section"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Practices</p><div><h2>Begin before you travel.</h2><p class="section-copy">You do not need to reach Dunhuang to create distance from noise. Begin with silence, walking, reflection, or a retreat shaped around the time you have.</p></div></div><div class="needs-list"><a class="need-row" href="/digital-detox/"><strong>Digital Sunset</strong><span>A boundary around constant input</span><span>→</span></a><a class="need-row" href="/personal-retreat/one-day/"><strong>One-Day Retreat</strong><span>A deliberate pause with a beginning and close</span><span>→</span></a><a class="need-row" href="/personal-retreat/questions-for-reflection/"><strong>Journaling</strong><span>Questions for the space between chapters</span><span>→</span></a></div><div class="actions"><a class="button secondary" href="/practices/">Explore Practices</a></div></div></section>
<section class="section dark"><div class="wrap builder-feature"><div><p class="eyebrow">Find Your Dunhuang Path</p><h2>Begin with the landscape inside this moment.</h2><p class="lede">A private, deterministic experience connecting your current state to a Dunhuang-inspired path and practical retreat.</p><div class="actions"><a class="button" href="/find-your-path/">Find My Path</a></div></div><div class="builder-preview" aria-label="Example path result"><div class="preview-row"><span>Current state</span><strong>Between chapters</strong></div><div class="preview-row"><span>Seeking</span><strong>Clarity</strong></div><div class="preview-row"><span>Landscape</span><strong>Desert</strong></div><div class="preview-row"><span>Path</span><strong>The Desert Crossing</strong></div></div></div></section>
<section class="section tint"><div class="wrap"><div class="intro-grid"><p class="eyebrow">Symbols</p><div><h2>Symbols carried across time.</h2><p class="section-copy">Cave, oasis, road, and manuscript—explored through historical context before contemporary reflection.</p></div></div><div class="needs-list"><a class="need-row" href="/symbols/#cave"><strong>Cave</strong><span>Shelter, image, archive</span><span>→</span></a><a class="need-row" href="/symbols/#oasis"><strong>Oasis</strong><span>Water, return, enoughness</span><span>→</span></a><a class="need-row" href="/symbols/#road"><strong>Road</strong><span>Movement, crossing, possibility</span><span>→</span></a></div><div class="actions"><a class="button secondary" href="/symbols/">Explore Symbols</a></div></div></section>
<section class="chapters"><div class="wrap"><article class="chapter"><div><span class="chapter-no">I</span><h2>Leave the Noise</h2><p>Step beyond the stream of alerts and unfinished demands.</p></div><div class="chapter-art" aria-hidden="true"></div></article><article class="chapter"><div><span class="chapter-no">II</span><h2>Cross the Distance</h2><p>Let the desert widen the frame around the question.</p></div><div class="chapter-art" aria-hidden="true"></div></article><article class="chapter"><div><span class="chapter-no">III</span><h2>Listen Within</h2><p>Notice what remains when the world stops supplying the next thought.</p></div><div class="chapter-art" aria-hidden="true"></div></article></div></section>
<section class="section tint"><div class="wrap"><p class="eyebrow">Journal</p><h2>Stories for quieter attention.</h2><div class="editorial-grid">{featured.map((article,index)=><a class:list={["story",{lead:index===0}]} href={`/${article.id}/`}><span class="story-meta">{article.data.cluster.replaceAll('-',' ')} · {index===0?'7':'5'} min</span><h3>{article.data.title}</h3><p>{article.data.description}</p></a>)}</div><div class="actions"><a class="button secondary" href="/journal/">Open the Journal</a></div></div></section>
<section class="section"><div class="wrap"><Newsletter /></div></section>
</Base>
<style>.hero-brand{margin:.05em 0 .25em;font:400 clamp(3rem,8vw,8rem)/.9 var(--serif);letter-spacing:-.04em;text-transform:uppercase;color:var(--sand-light)}.hero-dunhuang:before{background:radial-gradient(ellipse at 72% 42%,rgba(215,195,165,.58) 0,rgba(155,102,83,.22) 26%,transparent 55%),linear-gradient(168deg,transparent 0 53%,rgba(215,195,165,.22) 53.2% 54%,transparent 54.2%),linear-gradient(180deg,#30352f 0%,#655a48 47%,#181915 100%)}.dunhuang-origin{min-height:82vh;padding:9rem 0;align-items:center}.origin-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:8vw;align-items:end}.origin-grid>div:last-child>p:not(.lede){color:rgba(238,233,223,.76)}.manifesto-lines a{display:block;border-bottom:1px solid var(--line);padding:.35em 0;text-decoration:none}.manifesto-lines a:hover{color:var(--faded-clay)}@media(max-width:900px){.origin-grid{grid-template-columns:1fr;gap:3rem}.dunhuang-origin{padding:7rem 0}}</style>
