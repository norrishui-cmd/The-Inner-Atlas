---
import Base from '../../layouts/Base.astro';
import { localePages, localeAlternates, type LocalPage } from '../../lib/locale-content';

export function getStaticPaths(){
  return localePages.map(page=>({params:{locale:page.locale,slug:page.slug},props:{page}}));
}
const {page}=Astro.props as {page:LocalPage};
const siteOrigin=Astro.site??new URL('https://dunhuangwithin.com/');
const canonicalUrl=new URL(Astro.url.pathname,siteOrigin).href;
const alternates=localeAlternates(page.englishId);
const related=page.related.map(slug=>localePages.find(item=>item.locale===page.locale&&item.slug===slug)).filter(Boolean) as LocalPage[];
const labels=page.locale==='de'
  ? {home:'Startseite',section:'Dunhuang auf Deutsch',byline:'Redaktion von Dunhuang Within · Aktualisiert am 18. Juli 2026',questions:'Häufige Fragen',continue:'Weiter entdecken',source:'Quellen und Methodik',sourceCopy:'Diese Seite basiert auf derselben dokumentierten Quellenbasis wie die englische Hauptfassung. Zeitabhängige Angaben müssen vor der Reise offiziell geprüft werden.'}
  : {home:'Accueil',section:'Dunhuang en français',byline:'Rédaction de Dunhuang Within · Mis à jour le 18 juillet 2026',questions:'Questions fréquentes',continue:'Continuer la découverte',source:'Sources et méthode',sourceCopy:'Cette page repose sur la même base documentaire que la version anglaise principale. Toute information susceptible de changer doit être vérifiée officiellement avant le voyage.'};
const schema={'@context':'https://schema.org','@graph':[
  {'@type':'Article',headline:page.title,description:page.description,inLanguage:page.locale,datePublished:'2026-07-18',dateModified:'2026-07-18',mainEntityOfPage:canonicalUrl,author:{'@type':'Organization',name:'Dunhuang Within Editorial Team'},publisher:{'@id':'https://dunhuangwithin.com/#organization'},image:new URL(page.image,siteOrigin).href},
  {'@type':'BreadcrumbList',itemListElement:[{'@type':'ListItem',position:1,name:labels.home,item:new URL(`/${page.locale}/dunhuang/`,siteOrigin).href},{'@type':'ListItem',position:2,name:page.title,item:canonicalUrl}]},
  {'@type':'FAQPage',mainEntity:page.faq.map(item=>({'@type':'Question',name:item.question,acceptedAnswer:{'@type':'Answer',text:item.answer}}))}
]};
---
<Base lang={page.locale} title={page.seoTitle} description={page.description} image={page.image} type="article" schema={schema} alternates={alternates}>
  <article class="article localized-article">
    <nav class="breadcrumbs" aria-label="Breadcrumb"><a href={`/${page.locale}/dunhuang/`}>{labels.home}</a> / <span aria-current="page">{page.title}</span></nav>
    <p class="eyebrow">{labels.section}</p><h1>{page.title}</h1><p class="lede">{page.description}</p><p class="article-byline">{labels.byline}</p>
    <figure class="article-hero"><img src={page.image} alt={page.imageAlt} width="1200" height="800" loading="eager" fetchpriority="high" decoding="async" /></figure>
    <p>{page.intro}</p>
    {page.sections.map(section=><section><h2>{section.heading}</h2><p>{section.body}</p></section>)}
    <section class="article-faq" id="questions"><h2>{labels.questions}</h2>{page.faq.map(item=><details><summary>{item.question}</summary><p>{item.answer}</p></details>)}</section>
    <section><h2>{labels.source}</h2><p>{labels.sourceCopy}</p><p><a href={alternates.find(item=>item.lang==='en')?.href}>{page.locale==='de'?'Englische Hauptfassung und Quellen ansehen →':'Voir la version anglaise principale et ses sources →'}</a></p></section>
    <section><h2>{labels.continue}</h2><div class="related-grid">{related.map(item=><a href={`/${page.locale}/${item.slug}/`}><strong>{item.title}</strong><span>{item.description}</span></a>)}</div></section>
  </article>
</Base>
<style>.article-byline{font-size:.78rem;color:var(--ink-muted);margin-bottom:3rem}.article-hero{margin:0 0 4rem}.article-hero img{width:100%;height:auto;max-height:680px;object-fit:cover}.article-faq details{padding:1.2rem 0;border-bottom:1px solid var(--line)}.article-faq summary{cursor:pointer;font:400 1.2rem var(--serif)}.related-grid{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line)}.related-grid a{display:flex;flex-direction:column;gap:.5rem;padding:1.5rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);text-decoration:none}.related-grid span{font-size:.85rem;color:var(--ink-muted)}@media(max-width:650px){.related-grid{grid-template-columns:1fr}.related-grid a{border-right:0}}</style>
