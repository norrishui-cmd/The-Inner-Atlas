---
import Base from '../layouts/Base.astro'; import {archetypes} from '../lib/retreat-engine';
const data=JSON.stringify(archetypes);
---
<Base title="Build Your Personal Retreat" description="Create a practical, personalized retreat plan in five thoughtful steps—free, private, and without an account."><section class="hero"><div class="wrap builder"><p class="eyebrow">A free planning tool</p><h1>Build Your Personal Retreat</h1><p class="lede">Turn the time and place you have into a structured pause. Your answers stay in this browser.</p><div class="progress" aria-hidden="true"><span style="width:20%"></span></div><div id="builder" data-archetypes={data}></div></div></section></Base>
<script>
import { recommend, schedule, type Answers } from '../lib/retreat-engine'; import { subscribe } from '../lib/newsletter'; import { track } from '../lib/analytics';
const steps=[['away','What are you stepping away from?',['Constant noise','Too much screen time','Work pressure','Decision fatigue','A difficult chapter','Other people’s expectations']],['seek','What are you looking for?',['Silence','Clarity','Rest','Meaning','Courage','Renewal']],['duration','How much time do you have?',['2 hours','Half a day','1 day','A weekend','3 days','7 days']],['location','Where can you do it?',['At home','Nearby nature','A hotel','A remote destination','I’m not sure yet']],['landscape','Which landscape calls to you?',['Desert','Forest','Mountain','Ocean','Ancient place','Open road']]] as const;
const root=document.querySelector<HTMLElement>('#builder')!;let index=0;const answers={} as Answers;track('builder_start');
function show(){const [key,q,opts]=steps[index]!;root.innerHTML=`<p class="eyebrow">Step ${index+1} of 5</p><h2>${q}</h2><div class="choices">${opts.map(o=>`<button class="choice" data-value="${o}">${o}</button>`).join('')}</div>${index?'<button class="button secondary" data-back>Back</button>':''}`;document.querySelector('.progress span')?.setAttribute('style',`width:${(index+1)*20}%`);root.querySelectorAll<HTMLButtonElement>('[data-value]').forEach(b=>b.onclick=()=>{answers[key]=b.dataset.value!;track('builder_step',{step:index+1});if(index<4){index++;show()}else result()});root.querySelector<HTMLButtonElement>('[data-back]')?.addEventListener('click',()=>{index--;show()})}
function result(){const r=recommend(answers);const plan=schedule(answers.duration);history.replaceState(null,'',`?plan=${r.id}&duration=${encodeURIComponent(answers.duration)}`);track('builder_complete',{archetype:r.id});root.innerHTML=`<div class="result active"><p class="eyebrow">Your Personal Retreat</p><h1>${r.name}</h1><p class="lede">${r.tagline}</p><h2>Why this retreat</h2><p>Your wish for ${answers.seek.toLowerCase()} and pull toward ${answers.landscape.toLowerCase()} shaped this plan. It creates a clear boundary from ${answers.away.toLowerCase()} while fitting ${answers.duration.toLowerCase()} in ${answers.location.toLowerCase()}.</p><h2>Before you begin</h2><ul><li>Choose a clear start and finish time.</li><li>Set a phone boundary and tell one trusted person if unavailable.</li><li>Bring water and a notebook.</li><li>For outdoor plans, check conditions, access, and personal safety.</li></ul><h2>Your schedule</h2><div class="schedule">${plan.map(p=>`<h3>${p.time} — ${p.title}</h3><p>${p.detail}</p>`).join('')}</div><h2>Reflection questions</h2><ol>${r.reflectionQuestions.map(q=>`<li>${q}</li>`).join('')}</ol><h2>A place to think with</h2><p><a href="${r.recommendedPlaces[0]}">Explore a place inspired by this retreat →</a></p><div class="newsletter"><h2>Send my retreat plan</h2><p>Connect email delivery when the newsletter endpoint is configured.</p><form><input required type="email" name="email" aria-label="Email address" placeholder="you@example.com"><button class="button">Send my retreat plan</button></form><p class="status" role="status"></p></div><p><button class="button secondary" data-restart>Start again</button></p></div>`;root.querySelector('[data-restart]')?.addEventListener('click',()=>{index=0;show()});root.querySelector('form')?.addEventListener('submit',async e=>{e.preventDefault();const f=e.currentTarget as HTMLFormElement,s=f.querySelector('.status') as HTMLElement;s.textContent='Sending…';const out=await subscribe(new FormData(f).get('email')!.toString(),`retreat-${r.id}`);s.textContent=out.message})}
show();
</script>
