---
import Base from '../layouts/Base.astro';
import AmbientVideo from '../components/AmbientVideo.astro';
type Practice={name:string;text:string;link:string;image:string;alt:string;ratio:'landscape'|'square'|'portrait';caption?:string};
const practices:Practice[]=[
  {name:'Personal Retreat',text:'Protected time with an intention, a boundary, and enough structure to hold the pause.',link:'/personal-retreat/',image:'/images/dunhuang/practice-personal-retreat.jpg',alt:'Buddhist figure in a painted cave interior',ratio:'landscape'},
  {name:'Digital Detox',text:'Reduce optional input while preserving safety, access, and genuine connection.',link:'/digital-detox/',image:'/images/dunhuang/practice-digital-detox.jpg',alt:'Painted Buddhist cave interior with decorated ceiling and walls',ratio:'landscape'},
  {name:'Silence',text:'Begin with ten minutes without media, optimization, or the demand for an insight.',link:'/quiet-travel/',image:'/images/dunhuang/practice-silence.jpg',alt:'Person resting beneath a large reclining Buddha sculpture in an open landscape',ratio:'portrait'},
  {name:'One-Day Retreat',text:'A complete schedule for leaving noise, walking, reflection, and return.',link:'/personal-retreat/one-day/',image:'/images/dunhuang/practice-one-day-retreat.webp',alt:'View from a sand dune toward Crescent Lake and the surrounding desert',ratio:'portrait'},
  {name:'Weekend Retreat',text:'Arrival, a spacious middle day, and a deliberate return.',link:'/personal-retreat/weekend/',image:'/images/dunhuang/practice-weekend-retreat.jpg',alt:'Rock-cut Buddhist figure in a desert cliff sanctuary',ratio:'landscape'},
  {name:'Journaling Between Chapters',text:'Questions that leave enough room for an honest, unfinished answer.',link:'/personal-retreat/questions-for-reflection/',image:'/images/dunhuang/practice-journaling-between-chapters.jpg',alt:'Researcher studying an unfurled historic manuscript',ratio:'portrait',caption:'A manuscript-study image used as a visual reference for close reading and record-keeping.'}
];
---
<Base title="Practices" description="Dunhuang-inspired practices for silence, digital distance, reflection, and self-directed personal retreats.">
  <article class="article practices-page"><nav class="breadcrumbs"><a href="/">Home</a> / Practices</nav><p class="eyebrow">Begin before you travel</p><h1>Practices</h1><p class="lede">You do not need to reach Dunhuang to create distance from noise.</p><p>Each practice is designed to be usable where you are. The landscapes and cultural images are invitations to pay attention, not instructions from an ancient doctrine.</p>
    <div class="practice-list">{practices.map((practice,index)=><section class:list={['practice-card',{reverse:index%2===1}]}><div class="practice-copy"><p class="practice-number">{String(index+1).padStart(2,'0')}</p><h2>{practice.name}</h2><p>{practice.text}</p><a href={practice.link}>Begin the practice →</a></div><figure class:list={['practice-image',practice.ratio]}><img src={practice.image} alt={practice.alt} loading={index===0?'eager':'lazy'} decoding="async" />{practice.caption&&<figcaption>{practice.caption}</figcaption>}</figure></section>)}</div>
    <section class="practice-shop"><p class="eyebrow">Choose an anchor</p><h2>When a practice needs something to return to.</h2><p>A notebook, tactile object, textile, incense vessel or wearable symbol can support a practice by making it easier to remember. The object is an anchor for attention—not a replacement for rest, reflection or care.</p><div class="actions"><a class="button" href="/objects/">Visit the Shop</a><a class="button secondary" href="/symbols/">Choose a Symbol</a></div></section>
    <hr><a class="button" href="/build-your-retreat/">Build a Personal Retreat</a>
  </article>
  <div class="practice-film wrap"><AmbientVideo videoId="ubaYc97QXHs" eyebrow="A short visual" title="A pause with Dunhuang" copy="Let this quiet moving image mark the transition from reading into your own practice." /></div>
</Base>
<style>.practice-list{margin-top:5rem;border-top:1px solid var(--line)}.practice-card{display:grid;grid-template-columns:minmax(0,1fr) minmax(250px,.85fr);gap:clamp(2rem,6vw,7rem);align-items:center;padding:3.5rem 0;border-bottom:1px solid var(--line)}.practice-card.reverse .practice-copy{order:2}.practice-card.reverse .practice-image{order:1}.practice-number{margin:0 0 1.1rem;color:var(--ink-muted);font:500 .72rem var(--sans);letter-spacing:.16em}.practice-copy h2{margin:0 0 1.3rem;font-size:clamp(2.4rem,5vw,5.2rem)}.practice-copy p{max-width:34rem}.practice-copy a{display:inline-block;margin-top:1.6rem}.practice-image{margin:0;overflow:hidden;background:var(--ink)}.practice-image img{display:block;width:100%;height:100%;object-fit:cover;transition:transform .7s ease}.practice-card:hover .practice-image img{transform:scale(1.025)}.practice-image.landscape{aspect-ratio:3/2}.practice-image.square{aspect-ratio:1/1}.practice-image.portrait{aspect-ratio:3/4}.practice-image figcaption{padding:.65rem .8rem;background:var(--ink);color:var(--moonlight);font-size:.7rem;line-height:1.45}.practice-shop{margin-top:6rem;padding:clamp(2.5rem,6vw,5rem);background:var(--ink-deep);color:var(--moonlight)}.practice-shop h2{max-width:760px}.practice-shop p{max-width:700px}.practice-shop .eyebrow{color:var(--sand-light)}@media(max-width:720px){.practice-list{margin-top:3rem}.practice-card{display:flex;flex-direction:column;gap:1.6rem;align-items:stretch;padding:2.7rem 0}.practice-card.reverse .practice-copy,.practice-card.reverse .practice-image{order:initial}.practice-copy,.practice-image{width:100%}.practice-image.portrait{aspect-ratio:4/5}.practice-copy h2{font-size:2.7rem;margin-bottom:1rem}.practice-shop{margin-top:4rem}}</style>
